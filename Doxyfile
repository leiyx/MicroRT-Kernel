# Doxyfile 1.9.7 

#---------------------------------------------------------------------------
# 项目基本配置
#---------------------------------------------------------------------------

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "MicroRT-Kernel"
PROJECT_NUMBER         = 0.4
PROJECT_BRIEF          = "轻量级实时操作系统内核"
PROJECT_LOGO           =

# 输出目录
OUTPUT_DIRECTORY       = docs

# 创建输出目录下的子目录
CREATE_SUBDIRS         = NO

# 允许输出路径中的中文字符
OUTPUT_LANGUAGE        = Chinese

#---------------------------------------------------------------------------
# 输入配置
#---------------------------------------------------------------------------

# 输入目录（使用空格分隔多个目录）
INPUT                  = Kernel/Include \
                         Kernel/Source

# 输入文件的编码模式
INPUT_ENCODING         = UTF-8

# 文件名模式（* 匹配任意字符，递归搜索子目录）
FILE_PATTERNS          = *.h \
                         *.c \
                         *.md

# 递归扫描子目录
RECURSIVE              = YES

# 排除的文件和目录
EXCLUDE                = build/ \
                         build_* \
                         Test/ \
                         *_deps/

# 排除的文件模式
EXCLUDE_PATTERNS       = */build/* \
                         */test_* \
                         *_test.c

# 如果设置为 YES，符号链接将被跟随
EXCLUDE_SYMBOLS        = MRTK_EXPORT

# 示例路径（如果有示例代码）
EXAMPLE_PATH           = Test
EXAMPLE_RECURSIVE      = YES
EXAMPLE_PATTERNS       = *

#---------------------------------------------------------------------------
# 源代码浏览
#---------------------------------------------------------------------------

# 源代码浏览（生成 HTML 时会在文档中包含源代码）
SOURCE_BROWSER         = YES

# 内联源代码（将源代码直接嵌入到文档中）
INLINE_SOURCES         = YES

# 去除源代码路径前缀（显示更简洁的路径）
STRIP_FROM_PATH        = Kernel/

# 引用的 C++ 预处理符号
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# 生成引用关系图
REFERENCES_LINK_SOURCE = YES
VERBATIM_HEADERS       = YES

#---------------------------------------------------------------------------
# 提取配置
#---------------------------------------------------------------------------

# 提取私有成员（包括私有、保护成员）
EXTRACT_PRIVATE        = YES
EXTRACT_PRIV_VIRTUAL   = YES
EXTRACT_PACKAGE        = YES

# 提取静态成员
EXTRACT_STATIC         = YES

# 提取本地类（未在头文件中声明的类）
EXTRACT_LOCAL_CLASSES  = YES

# 提取本地方法（定义在实现文件中的方法）
EXTRACT_LOCAL_METHODS  = YES

# 提取所有成员（包括匿名成员和未文档化的成员）
EXTRACT_ALL            = NO

#---------------------------------------------------------------------------
# 文档生成选项
#---------------------------------------------------------------------------

# 生成 HTML 文档
GENERATE_HTML          = YES

# HTML 输出目录
HTML_OUTPUT            = html

# HTML 文档扩展名
HTML_FILE_EXTENSION    = .html

# 使用 HTML 帮助格式（CHM）
GENERATE_HTMLHELP      = NO

# 生成树状导航栏
GENERATE_TREEVIEW      = YES

# 树视图宽度
TREEVIEW_WIDTH         = 250

# 禁用索引
DISABLE_INDEX          = NO

# 生成 LaTeX 文档
GENERATE_LATEX         = NO

# 生成 RTF 文档
GENERATE_RTF           = NO

# 生成 Man 手册
GENERATE_MAN           = NO

# 生成 XML 文档
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# 预处理配置
#---------------------------------------------------------------------------

# 启用预处理
ENABLE_PREPROCESSING   = YES

# 宏定义（类似 gcc -D）
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
EXPAND_AS_DEFINED      = MRTK_INLINE \
                         MRTK_EXPORT

# 搜索包含文件
SKIP_FUNCTION_MACROS   = YES

# 预定义的宏
PREDEFINED             = __cplusplus \
                         MRTK_USING_TIMER=1 \
                         MRTK_USING_MUTEX=1 \
                         MRTK_USING_SEMAPHORE=1 \
                         MRTK_USING_MESSAGE_QUEUE=1 \
                         MRTK_USING_MAILBOX=1 \
                         MRTK_USING_EVENT=1 \
                         MRTK_USING_MEM_HEAP=1 \
                         MRTK_USING_MEM_POOL=1 \
                         MRTK_DEBUG=1

#---------------------------------------------------------------------------
# 构建配置
#---------------------------------------------------------------------------

# 提取版本信息（从版本控制系统）
EXTRACT_ANON_NS        = NO

# 排序成员：按字母顺序排序成员
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES
SORT_GROUP_NAMES       = YES

# 按作用域分组
SORT_BY_SCOPE_NAME     = YES

# 最大化描述行宽
MAX_INITIALIZER_LINES  = 30

# 显示包含文件
SHOW_INCLUDE_FILES     = YES

# 显示分组
SHOW_GROUPED_MEMB_DOC  = YES

# 显示用于文件的列表
SHOW_FILES             = YES

# 显示命名空间
SHOW_NAMESPACES        = YES

# 显示目录
SHOW_DIRECTORIES       = YES

#---------------------------------------------------------------------------
