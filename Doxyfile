#---------------------------------------------------------------------------

# 警告级别
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_UNDOCUMENTED_PARAM = YES
WARN_IF_INCOMPLETE_DOC = YES

# 警告格式
WARN_FORMAT            = "$file:$line: $text"
WARN_LOGFILE           = docs/doxygen_warnings.log

# 格式化细节
# 详细输出
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES

#---------------------------------------------------------------------------
# 输出消息
